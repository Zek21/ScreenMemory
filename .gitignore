# Credentials and secrets
.env
*.key
keystore.dat
data/secrets.json

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# Databases
*.db
*.db-shm
*.db-wal
*.sqlite

# Data directory -- exclude ALL runtime state and config (SECURITY: no internal files public)
data/*
!data/.gitkeep
!data/paper_final_checklist.md

# Skynet operational protocol -- NEVER commit publicly
AGENTS.md

# Skynet internal architecture docs -- NEVER commit publicly
docs/DELIVERY_PIPELINE.md
docs/DAEMON_ARCHITECTURE.md
docs/BUS_COMMUNICATION.md
docs/SELF_AWARENESS_ARCHITECTURE.md
docs/SKYNET_ARCHITECTURE_OVERVIEW.md
docs/SKYNET_API.md
docs/SKYNET_TOOLS.md
docs/SKYNET_MANUAL.md
docs/WORKER_BOOT_PROCEDURE.txt

# Logs
logs/
!logs/.gitkeep
!logs/__init__.py

# Screenshots (runtime captures)
screenshots/
!screenshots/.gitkeep

# Runtime PID/state files
*.pid

# IDE
.vscode/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Node
node_modules/

# Chrome bridge dist/proof artifacts
tools/chrome_bridge/dist/proof/chrome-profile/
tools/chrome_bridge/server-live.log

# Playwright MCP logs
tools/.playwright-mcp/

# Lance vector DB
*.lance/

# Chrome CDP non-default user data (Chrome v146+ requires this for --remote-debugging-port)
data/chrome_cdp_userdata/
